# ─────────────────────────────────────────────────────────
#  UpSkillX — Environment Variables Template
#  Copy this to .env.local for local dev (never commit .env)
#  Add these as Cloudflare Pages environment variables
# ─────────────────────────────────────────────────────────

# ── Firebase (Client SDK — safe to expose) ────────────────
FIREBASE_API_KEY=your_firebase_api_key_here
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=123456789
FIREBASE_APP_ID=1:123456789:web:abcdef

# ── Admin Auth (SERVER-SIDE ONLY — never expose in frontend) ──
ADMIN_ID=admin
ADMIN_PASS=ADMIN@2026
ADMIN_SECRET=change_this_to_a_long_random_secret_string

# ── Email via SendGrid ─────────────────────────────────────
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=official.tanmaytuli@gmail.com
FROM_NAME=UpSkillX by Tanmay Tuli

# ── Cloudflare (auto-provided, no action needed) ──────────
# CLOUDFLARE_ACCOUNT_ID=auto
# CLOUDFLARE_API_TOKEN=auto
