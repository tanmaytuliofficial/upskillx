rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ──────────────────────────────────────────────────────────────
    match /users/{userId} {
      // Any authenticated user can read/write their OWN document
      allow read, write: if request.auth != null && request.auth.uid == userId;
      // No one else can read user docs directly
    }

    // ── Courses ────────────────────────────────────────────────────────────
    match /courses/{courseId} {
      // Anyone (even unauthenticated) can read course listings
      allow read: if true;
      // Only authenticated users can update enrollment count
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['enrollmentCount']);
      // Writes (create/delete/full update) handled server-side via Worker
      allow create, delete: if false;
    }

    // ── Lectures (subcollection) ───────────────────────────────────────────
    match /courses/{courseId}/lectures/{lectureId} {
      allow read: if request.auth != null;
      allow write: if false; // Admin only via Worker
    }

    // ── Notes (subcollection) ─────────────────────────────────────────────
    match /courses/{courseId}/notes/{noteId} {
      allow read: if request.auth != null;
      allow write: if false; // Admin only via Worker
    }

    // ── Doubts ────────────────────────────────────────────────────────────
    match /doubts/{doubtId} {
      // Authenticated users can create doubts
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid;
      // Users can read their own doubts
      allow read: if request.auth != null
        && resource.data.uid == request.auth.uid;
      // No updates or deletes from client
      allow update, delete: if false;
    }

    // ── Announcements ─────────────────────────────────────────────────────
    match /announcements/{annId} {
      // All authenticated users can read
      allow read: if request.auth != null;
      // No client writes
      allow write: if false;
    }

    // ── Chats ─────────────────────────────────────────────────────────────
    match /chats/{chatId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }
  }
}
